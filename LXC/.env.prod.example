# ag.flow — variables de production (sur LXC 203).
#
# Copier en `/opt/agflow/.env.prod` (NE PAS COMMITER) et remplir les secrets.
# Le compose lit ce fichier via `--env-file` ou variable shell.

# ─── Postgres ────────────────────────────────────────────────────────────────
# Generate avec : openssl rand -base64 32
POSTGRES_PASSWORD=

# ─── Keycloak (OIDC) ─────────────────────────────────────────────────────────
KEYCLOAK_ISSUER=https://security.yoops.org/realms/yoops
KEYCLOAK_CLIENT_ID=workflow-agflow
# Récupéré depuis Keycloak admin console (client `workflow-agflow` → onglet Credentials)
KEYCLOAK_CLIENT_SECRET=

# ─── ag.flow ─────────────────────────────────────────────────────────────────
# URL publique servie par Cloudflare Tunnel
AGFLOW_PUBLIC_BASE_URL=https://workflow-agflow.yoops.org

# Generate avec : openssl rand -hex 32
SESSION_COOKIE_SECRET=

LOG_LEVEL=INFO
