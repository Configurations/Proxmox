# ── agflow-logs / LXC 116 — variables d'environnement ──────────────────────────
# Copier ce fichier vers .env et renseigner les valeurs avant `docker compose up -d`.

# Mot de passe du compte admin technique Grafana (fallback si Keycloak indisponible)
# Générer un mot de passe fort : `openssl rand -base64 24`
GRAFANA_ADMIN_PASSWORD=changeme-please

# Secret du client OIDC `grafana` créé dans Keycloak (realm `yoops`)
# Récupérable dans la UI Keycloak : Clients > grafana > Credentials > Secret
KEYCLOAK_GRAFANA_CLIENT_SECRET=changeme-from-keycloak
